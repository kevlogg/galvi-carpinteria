rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Solo usuarios cuyo UID está en config/admins pueden escribir en products/categories
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/config/admins)
        && request.auth.uid in get(/databases/$(database)/documents/config/admins).data.uids;
    }

    // Cualquiera puede leer productos y categorías (datos públicos de la tienda)
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // config/admins: cualquier autenticado puede leer (para que la app sepa si es admin); solo admins pueden actualizar
    match /config/admins {
      allow read: if request.auth != null;
      allow update: if isAdmin();
      allow create: if request.auth != null
        && !exists(/databases/$(database)/documents/config/admins)
        && request.auth.uid in request.resource.data.uids;
    }

    // Solicitudes a medida: cualquiera puede crear; solo admins leer/actualizar/borrar
    match /custom_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Mensajes de contacto: cualquiera puede crear; solo admins leer/actualizar/borrar
    match /contact_messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Pedidos: cualquiera puede crear; solo admins leer/actualizar/borrar
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // El resto de colecciones: denegado por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
