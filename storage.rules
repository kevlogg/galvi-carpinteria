rules_version = '2';
// Permite lectura pública de archivos (para que las imágenes de productos se vean en la web).
// Escritura solo con autenticación (tu app sube con la cuenta de servicio).
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
